@model AdminDashboardViewModel
@{ ViewData["Title"] = "Admin Dashboard"; }

<div class="mb-4">
    <h1 class="page-title"><i class="bi bi-shield-lock-fill me-2" style="opacity:.4"></i>Admin Dashboard</h1>
    <p class="page-subtitle">User management and system configuration</p>
</div>

<!-- Stats -->
<div class="row g-3 mb-4">
    <div class="col-6 col-md-3">
        <div class="stat-card stat-primary">
            <div class="stat-number">@Model.AllUsers.Count</div>
            <div class="stat-label"><i class="bi bi-people me-1"></i>Total Users</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="stat-card stat-info">
            <div class="stat-number">@Model.TotalProposals</div>
            <div class="stat-label"><i class="bi bi-file-text me-1"></i>Proposals</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="stat-card stat-success">
            <div class="stat-number">@Model.ConfirmedMatches</div>
            <div class="stat-label"><i class="bi bi-check-circle me-1"></i>Confirmed</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="stat-card stat-warning">
            <div class="stat-number">@Model.PendingProposals</div>
            <div class="stat-label"><i class="bi bi-clock me-1"></i>Pending</div>
        </div>
    </div>
</div>

<!-- Create User -->
<div class="card mb-4">
    <div class="card-header bw-dark">
        <i class="bi bi-person-plus me-2"></i>Create New User
    </div>
    <div class="card-body">
        <form asp-controller="Admin" asp-action="CreateUser" method="post">
            <div class="row g-2 align-items-end">
                <div class="col-md-3">
                    <label class="form-label">Full Name</label>
                    <input name="FullName" class="form-control" placeholder="Full Name" required />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Email</label>
                    <input name="Email" type="email" class="form-control" placeholder="Email" required />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Role</label>
                    <select name="Role" class="form-select">
                        <option value="Student">Student</option>
                        <option value="Supervisor">Supervisor</option>
                        <option value="ModuleLeader">Module Leader</option>
                        <option value="Admin">Admin</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label">Password</label>
                    <input name="Password" type="password" class="form-control" placeholder="Password" required />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Confirm</label>
                    <input name="ConfirmPassword" type="password" class="form-control" placeholder="Confirm" required />
                </div>
                <div class="col-12 mt-2">
                    <button type="submit" class="btn btn-primary btn-sm">
                        <i class="bi bi-plus-circle me-1"></i>Create User
                    </button>
                </div>
            </div>
        </form>
    </div>
</div>

<!-- Users Table -->
<div class="card">
    <div class="card-header">
        <i class="bi bi-people-fill me-2"></i>All Users
        <span class="badge bg-secondary ms-2">@Model.AllUsers.Count</span>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Role</th>
                        <th style="width:80px">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var u in Model.AllUsers)
                    {
                        <tr>
                            <td class="fw-semibold">@u.FullName</td>
                            <td class="text-muted small">@u.Email</td>
                            <td><span class="badge @GetRoleBadge(u.Role)">@u.Role</span></td>
                            <td>
                                @if (u.Email != "admin@blindmatch.ac.lk")
                                {
                                    <form asp-action="DeleteUser" asp-route-id="@u.Id" method="post" class="d-inline"
                                          onsubmit="return confirm('Delete @u.FullName?')">
                                        <button type="submit" class="btn btn-outline-danger btn-sm">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                }
                                else
                                {
                                    <span class="small text-muted">Protected</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@functions {
    string GetRoleBadge(string r) => r switch {
        "Admin"        => "bg-dark",
        "ModuleLeader" => "bg-primary",
        "Supervisor"   => "bg-success",
        "Student"      => "bg-secondary",
        _              => "bg-secondary"
    };
}
