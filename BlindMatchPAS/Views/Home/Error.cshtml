@{ ViewData["Title"] = "Error"; }

<div class="row justify-content-center mt-5">
    <div class="col-md-6 text-center">
        <div class="card">
            <div class="card-body py-5">
                <i class="bi bi-exclamation-triangle" style="font-size:3rem;opacity:.3"></i>
                <h3 class="fw-bold mt-3">Something went wrong</h3>
                <p class="text-muted">An unexpected error occurred. Please try again.</p>
                <a href="/" class="btn btn-primary mt-2">
                    <i class="bi bi-house me-1"></i>Go Home
                </a>
            </div>
        </div>
    </div>
</div>
